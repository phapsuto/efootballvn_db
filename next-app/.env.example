MONGODB_URI=mongodb://127.0.0.1:27017/efootball_vn
# Optional: override DB name if your URI does not include one
# MONGODB_DB_NAME=efootball_vn

# Optional: override collection names
# PLAYERS_COLLECTION=players
# MANAGERS_COLLECTION=managers
# PACKS_COLLECTION=packs
# COMMUNITY_COLLECTION=community_profiles
# LEAGUE_COLLECTION=league_rankings
# PLAYER_BUILDS_COLLECTION=player_builds
# COMMUNITY_FOLLOWS_COLLECTION=community_follows

# Optional: shared scrape -> import pipeline paths/status
# SCRAPER_IMPORT_REPORT_PATH=../scraped-output/status/import-report.json
# SCRAPER_TIMEZONE=Asia/Ho_Chi_Minh
# SCRAPER_BASE_CRON=12 * * * *
# SCRAPER_PEAK_CRON=12,42 16-23 * * 1,4
# SCRAPER_MAX_PLAYERS_BASE=40
# SCRAPER_MAX_PLAYERS_PEAK=80

# === Security ===
# REQUIRED in production. 32+ random chars used to HMAC-sign the anonymous
# viewer cookie. Generate with:  openssl rand -base64 48
# Without this, the cookie falls back to an insecure dev secret (warning logged).
EFVN_VIEWER_COOKIE_SECRET=change-me-with-openssl-rand-base64-48

# Comma-separated list of extra hostnames allowed to send state-changing API
# requests (POST/PUT/PATCH/DELETE). The request's own Host is always allowed.
# Add CDN / preview / staging hosts here if they differ from the primary origin.
# Example: EFVN_ALLOWED_ORIGINS=efootball-vn.com,www.efootball-vn.com,preview.efootball-vn.com
# EFVN_ALLOWED_ORIGINS=
